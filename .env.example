# Honcho connection — copy to .env for local runs (never commit real secrets).

# Your Honcho instance. Defaults to Honcho cloud; set to your own URL if self-hosting.
HONCHO_BASE_URL=https://api.honcho.dev

# Honcho API key (cloud) or a workspace-scoped token (self-hosted). Required at runtime.
HONCHO_API_KEY=

# Identity defaults / fallbacks. Open WebUI supplies the subject per request (the login email,
# via the X-Honcho-User-Email header); these apply when it does not.
HONCHO_DEFAULT_WORKSPACE=default
HONCHO_DEFAULT_PEER=user

# The speaker peer authors the assistant's messages (provenance only). In unified mode it is
# NOT the conclusion observer — conclusions stay self-scoped to the subject, so memory is shared
# with the user's other Honcho clients.
HONCHO_SPEAKER_PEER=open_webui

# Observation mode: "unified" (self-scoped; shares memory across clients) or "directional".
HONCHO_OBSERVATION_MODE=unified

# How to derive the subject peer from the Open WebUI login email: localpart | email | userid.
HONCHO_PEER_DERIVATION=localpart

# Optional bearer token protecting the tool server (Open WebUI sends it). Blank => no auth
# (trusted internal network only).
TOOL_SERVER_API_KEY=

# Tool server bind.
TOOL_SERVER_HOST=0.0.0.0
TOOL_SERVER_PORT=8000

# Fail-open timeout (seconds) for Honcho calls.
HONCHO_TIMEOUT_SECONDS=8.0
